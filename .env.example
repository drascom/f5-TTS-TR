# Runtime
PORT=5400
ORPHEUS_DEVICE=cuda
ORPHEUS_MODEL_DIR=.
PROMPT_DATA_DIR=./data
OUTPUT_DIR=./inference

# Generation defaults
ORPHEUS_MAX_NEW_TOKENS=512
ORPHEUS_MIN_NEW_TOKENS=256
ORPHEUS_TEMPERATURE=0.2
ORPHEUS_TOP_K=10
ORPHEUS_TOP_P=0.9
ORPHEUS_REPETITION_PENALTY=1.9

# Install/bootstrap helpers
HF_REPO=Karayakar/Orpheus-TTS-Turkish-PT-5000
TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
# HF_TOKEN=

# Gunicorn (used by start.sh when available)
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=300
